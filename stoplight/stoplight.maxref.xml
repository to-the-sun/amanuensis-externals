<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<?xml-stylesheet devhelp="true" type="text/xsl" href="pb-patcher.xsl"?>
<c74object name="stoplight" module="max" category="Data">
	<digest>A data gate for Max messages</digest>
	<description>The `stoplight` object passes messages from the left inlet to its outlet. It has a second control inlet to eventually gate messages based on its value.</description>
	<!--METADATA-->
	<metadatalist>
		<metadata name="author">Jules</metadata>
		<metadata name="tag">Data</metadata>
	</metadatalist>
	<!--INLETS-->
	<inletlist>
		<inlet id="1" type="anything">
			<digest>Inlet 0: Accepts anything to be passed through.</digest>
			<description>Any message received on this inlet is immediately passed to the outlet.</description>
		</inlet>
		<inlet id="2" type="int">
			<digest>Inlet 1: Control (0 or non-zero).</digest>
			<description>Values here will eventually control whether messages from Inlet 0 are passed through.</description>
		</inlet>
	</inletlist>
	<!--OUTLETS-->
	<outletlist>
		<outlet id="1" type="anything">
			<digest>Outlet 1: Passed-through Data.</digest>
			<description>The data passed from Inlet 0.</description>
		</outlet>
	</outletlist>
	<!--ARGUMENTS-->
	<objarglist />
	<!--MESSAGES-->
	<methodlist>
		<method name="bang">
			<digest>Pass through bang</digest>
		</method>
		<method name="int">
			<digest>Pass through int</digest>
		</method>
		<method name="float">
			<digest>Pass through float</digest>
		</method>
		<method name="list">
			<digest>Pass through list</digest>
		</method>
		<method name="anything">
			<digest>Pass through anything else</digest>
		</method>
	</methodlist>
	<!--ATTRIBUTES-->
	<attributelist />
	<!--SEEALSO-->
	<seealsolist>
		<seealso name="weaver~" />
		<seealso name="rebar" />
	</seealsolist>
</c74object>
